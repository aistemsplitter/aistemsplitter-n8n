{
  "name": "@aistemsplitter/n8n-nodes-aistemsplitter",
  "version": "0.1.9",
  "description": "n8n community node and automation integration helpers for AIStemSplitter.",
  "author": {
    "name": "AIStemSplitter",
    "email": "support@aistemsplitter.org",
    "url": "https://aistemsplitter.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aistemsplitter/aistemsplitter-n8n.git"
  },
  "homepage": "https://aistemsplitter.org",
  "bugs": {
    "url": "https://github.com/aistemsplitter/aistemsplitter-n8n/issues"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "n8n-node",
    "aistemsplitter",
    "audio",
    "stem-splitter",
    "vocal-remover"
  ],
  "main": "dist/shared/aistemsplitter-api.js",
  "types": "dist/shared/aistemsplitter-api.d.ts",
  "files": [
    "dist",
    "pipedream",
    "make-submission.md",
    "zapier-submission.md",
    "README.md",
    "LICENSE"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/AIStemSplitterApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/AIStemSplitter/AIStemSplitter.node.js"
    ]
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "pretest": "npm run build",
    "test": "node --test tests/*.test.mjs tests/*.test.cjs",
    "smoke": "node -e \"require('./dist/shared/aistemsplitter-api.js'); require('./dist/nodes/AIStemSplitter/AIStemSplitter.node.js'); require('./dist/credentials/AIStemSplitterApi.credentials.js'); console.log('AIStemSplitter automation helpers loaded')\"",
    "pack:dry-run": "npm pack --dry-run"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "n8n-workflow": "^1.82.0",
    "typescript": "^5.4.5"
  },
  "license": "MIT"
}
