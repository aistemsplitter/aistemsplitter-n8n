{
  "name": "@aistemsplitter/n8n-nodes-aistemsplitter",
  "version": "0.1.5",
  "description": "n8n community node and automation integration helpers for AIStemSplitter.",
  "type": "module",
  "author": {
    "name": "AIStemSplitter",
    "email": "support@aistemsplitter.org",
    "url": "https://aistemsplitter.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aistemsplitter/aistemsplitter-n8n.git"
  },
  "homepage": "https://aistemsplitter.org",
  "bugs": {
    "url": "https://github.com/aistemsplitter/aistemsplitter-n8n/issues"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "n8n-node",
    "aistemsplitter",
    "audio",
    "stem-splitter",
    "vocal-remover"
  ],
  "files": [
    "credentials",
    "nodes",
    "pipedream",
    "shared",
    "make-submission.md",
    "zapier-submission.md",
    "README.md",
    "LICENSE"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "credentials/AIStemSplitterApi.credentials.js"
    ],
    "nodes": [
      "nodes/AIStemSplitter/AIStemSplitter.node.js"
    ]
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "smoke": "node -e \"Promise.all([import('./shared/aistemsplitter-api.mjs'), import('./nodes/AIStemSplitter/AIStemSplitter.node.js'), import('./credentials/AIStemSplitterApi.credentials.js')]).then(() => console.log('AIStemSplitter automation helpers loaded'))\"",
    "pack:dry-run": "npm pack --dry-run"
  },
  "license": "MIT"
}
